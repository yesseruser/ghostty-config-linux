font-family = JetBrains Mono
theme = Gruvbox Material Dark
window-padding-x = 1
window-padding-y = 1
mouse-hide-while-typing = true

# Config stuff
keybind = ctrl+shift+,=reload_config

# New stuff
keybind = ctrl+n>t=new_tab
keybind = ctrl+n>s>h=new_split:left
keybind = ctrl+n>s>j=new_split:down
keybind = ctrl+n>s>k=new_split:up
keybind = ctrl+n>s>l=new_split:right
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab

# Close stuff
keybind = ctrl+r>t=close_tab
keybind = ctrl+r>s=close_surface

# Tab switching
keybind = ctrl+t>physical:one=goto_tab:1
keybind = ctrl+t>physical:two=goto_tab:2
keybind = ctrl+t>physical:three=goto_tab:3
keybind = ctrl+t>physical:four=goto_tab:4
keybind = ctrl+t>physical:five=goto_tab:5
keybind = ctrl+t>physical:six=goto_tab:6
keybind = ctrl+t>physical:seven=goto_tab:7
keybind = ctrl+t>physical:eight=goto_tab:8
keybind = ctrl+t>physical:nine=goto_tab:9
keybind = ctrl+t>physical:zero=goto_tab:10

# Split switching
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+j=goto_split:down
keybind = ctrl+shift+k=goto_split:up
keybind = ctrl+shift+l=goto_split:right

# Misc stuff
keybind = ctrl+shift+c=copy_to_clipboard

# Shaders
custom-shader = shaders/cursor_smear.glsl
